# Single-app configuration (simplest setup)
APPSHEET_APP_ID=your-app-id-here
APPSHEET_API_KEY=V2-your-api-key-here
APPSHEET_REGION=global

# Optional: comma-separated table names for schema discovery
APPSHEET_TABLES=Table1,Table2,Table3

# Optional: path to multi-app config file
# APPSHEET_CONFIG_PATH=~/.appsheet-mcp.json

# Optional: debug logging
# APPSHEET_DEBUG=true
